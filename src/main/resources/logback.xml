<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- File appender configuration -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>explorer-davidparry.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Daily rollover with compression -->
            <fileNamePattern>explorer-davidparry-%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <!-- Keep 30 days' worth of history -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="ERROR">
        <appender-ref ref="FILE" />
    </root>

    <!-- Set specific package log levels -->
    <logger name="io.modelcontextprotocol" level="ERROR" />
    <logger name="com.davidparry" level="DEBUG" />
</configuration>
